{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "./.codex/hooks/automation-vercel-environment-sync-posttooluse-posttooluse-1-1.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "./.codex/hooks/automation-vercel-environment-sync-sessionstart-sessionstart-1-1.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
