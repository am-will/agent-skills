{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./.codex/hooks/automation-deployment-health-monitor-posttooluse-posttooluse-1-1.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "./.codex/hooks/automation-deployment-health-monitor-sessionstart-sessionstart-1-1.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
